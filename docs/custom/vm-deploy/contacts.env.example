# ~/.openclaw/secrets/contacts.env
#
# Copy this file to ~/.openclaw/secrets/contacts.env on the VM and fill in real values.
# This file is never committed to the repo.
# Scripts source it with: source ~/.openclaw/secrets/contacts.env
#
# Usage example (bash):
#   source ~/.openclaw/secrets/contacts.env
#   openclaw cron add --to "$OWNER_WA" --message "..."

# Primary WhatsApp number (your own number)
OWNER_WA=+27700000000

# Accountability partner 1 (spouse / partner)
ALICIA_WA=+27700000001

# Accountability partner 2 (business partner / friend)
RHYNO_WA=+27700000002
